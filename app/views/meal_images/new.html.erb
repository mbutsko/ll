<div class="min-h-screen bg-gray-50">
  <nav class="bg-white border-b border-gray-200">
    <div class="max-w-5xl mx-auto px-6 py-4 flex items-center justify-between">
      <span class="text-lg font-semibold text-gray-900">Log Meal from Image</span>
      <%= link_to "Back", root_path, class: "text-sm text-gray-500 hover:text-gray-700 transition" %>
    </div>
  </nav>

  <main class="max-w-3xl mx-auto px-6 py-10">
    <div class="bg-white rounded-xl shadow-sm border border-gray-200 p-6">
      <%= form_with url: meal_images_path, method: :post, multipart: true, class: "space-y-5" do |f| %>
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1">Meal Photo</label>
          <%= f.file_field :image, accept: "image/*", capture: "environment", required: true,
                class: "w-full rounded-lg border border-gray-300 px-4 py-2 text-gray-900 file:mr-4 file:py-1 file:px-3 file:rounded-lg file:border-0 file:text-sm file:font-medium file:bg-blue-50 file:text-blue-700 hover:file:bg-blue-100 transition" %>
          <p class="text-xs text-gray-400 mt-1">Take a photo or upload an image of your meal.</p>
        </div>

        <div class="pt-2">
          <%= f.submit "Analyze & Log", class: "bg-blue-600 text-white font-medium px-5 py-2 rounded-lg hover:bg-blue-700 active:bg-blue-800 transition cursor-pointer",
                data: { turbo_submits_with: "Analyzing..." } %>
          <%= link_to "Cancel", root_path, class: "ml-3 text-sm text-gray-500 hover:text-gray-700 transition" %>
        </div>
      <% end %>
    </div>
  </main>
</div>
